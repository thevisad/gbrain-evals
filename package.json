{
  "name": "gbrain-evals",
  "version": "0.1.0",
  "description": "BrainBench — public benchmark for personal knowledge agent stacks. Consumes gbrain as a library.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garrytan/gbrain-evals.git"
  },
  "scripts": {
    "test": "bun test test/eval/",
    "eval:run": "bun eval/runner/multi-adapter.ts",
    "eval:run:dev": "BRAINBENCH_N=1 bun eval/runner/multi-adapter.ts",
    "eval:world:view": "bun eval/cli/world-view.ts",
    "eval:world:render": "bun eval/cli/world-view.ts --no-open",
    "eval:query:validate": "bun eval/cli/query-validate.ts",
    "eval:query:new": "bun eval/cli/query-new.ts",
    "eval:type-accuracy": "bun eval/runner/type-accuracy.ts",
    "eval:generate-amara-life": "bun eval/generators/amara-life-gen.ts",
    "eval:generate-amara-life:dry": "bun eval/generators/amara-life-gen.ts --dry-run",
    "eval:brainbench": "bun eval/runner/all.ts",
    "eval:brainbench:smoke": "BRAINBENCH_N=1 BRAINBENCH_CONCURRENCY=2 bun eval/runner/all.ts",
    "eval:brainbench:published": "BRAINBENCH_N=10 BRAINBENCH_CONCURRENCY=2 bun eval/runner/all.ts",
    "eval:cat6": "bun eval/runner/cat6-prose-scale.ts",
    "eval:cat11": "bun eval/runner/cat11-multimodal.ts",
    "eval:generate-amara-life-v2": "bun eval/generators/amara-life-v2-gen.ts",
    "eval:generate-amara-life-v2:dry": "bun eval/generators/amara-life-v2-gen.ts --dry-run",
    "eval:generate-amara-life-v2:check": "bun eval/generators/amara-life-v2-gen.ts --check"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "gbrain": "github:garrytan/gbrain#master"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "pdf-parse": "^2.4.5"
  },
  "keywords": [
    "gbrain",
    "brainbench",
    "benchmark",
    "personal-knowledge-agent",
    "retrieval-eval",
    "rag-benchmark"
  ]
}
